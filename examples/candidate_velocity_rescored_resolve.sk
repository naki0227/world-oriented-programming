sphere A
plane floor
position(A) = (0, 2, 0)
velocity(A) = (0, 0, 0)
radius(A) = 1

action:
    candidate_velocity(A, alpha) = (2, 0, 0) score 5
    candidate_velocity(A, beta) = (-2, 0, 0) score 5
    defer_on_ambiguous_top(A)
    resolve_deferred_at(A, 1)
    rescore_candidate_at(A, beta, 1, 1)

observe:
    snapshot at 0
    snapshot at 1
