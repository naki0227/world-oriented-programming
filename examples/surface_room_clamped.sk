sphere A
plane floor
plane ceiling
plane left_wall
plane right_wall

position(A) = (1.2, 2.6, 0)
velocity(A) = (-1.2, 1.0, 0)
radius(A) = 0.8

normal(floor) = (0, 1, 0)
offset(floor) = 0

normal(ceiling) = (-0.5, -1, 0)
offset(ceiling) = -4

normal(left_wall) = (1, 0, 0)
offset(left_wall) = 0

normal(right_wall) = (-1, 0, 0)
offset(right_wall) = -5

constraint:
    inside_planes(A, floor, ceiling, left_wall, right_wall, clamp)

observe:
    snapshot at 0
    snapshot at 1
    snapshot at 2
